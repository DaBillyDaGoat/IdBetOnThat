# Copy to .env and fill in. Never commit .env.
# ------------------------------------------------------------

# Postgres connection string (Neon, Supabase, or local).
# Neon: copy from your project dashboard. Use the pooled connection.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Direct (non-pooled) connection, used by Prisma migrations only.
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-random-32-byte-base64-string"

# Your site's public URL. localhost in dev, https://idbetonthat.com in prod.
AUTH_URL="http://localhost:3000"

# Resend (https://resend.com). Free tier covers dev.
RESEND_API_KEY="re_your_resend_api_key"

# Verified sender. In dev you can use Resend's onboarding@resend.dev.
# In prod, verify idbetonthat.com in Resend and use noreply@idbetonthat.com.
EMAIL_FROM="onboarding@resend.dev"
